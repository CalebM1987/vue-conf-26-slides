#!/usr/bin/env bash
set -euo pipefail

if [ $# -lt 1 ]; then
  echo "Usage: click-css <selector>" >&2
  exit 1
fi

# shellcheck source=_resolve-session
source "$(dirname "$0")/_resolve-session"

SELECTOR="$1"
SELECTOR_ESC="${SELECTOR//\'/\'}"
playwright-cli $_SESSION_FLAG run-code "async page => { await page.locator('${SELECTOR_ESC}').click(); }"
