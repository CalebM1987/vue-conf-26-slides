#!/usr/bin/env bash
set -euo pipefail

if [ $# -lt 1 ]; then
  echo "Usage: auth-save <name>" >&2
  exit 1
fi

# shellcheck source=_resolve-session
source "$(dirname "$0")/_resolve-session"

mkdir -p "$_SKILL_DIR/.playwright-skill/auth"
playwright-cli $_SESSION_FLAG state-save "$_SKILL_DIR/.playwright-skill/auth/$1.json"
echo "Auth profile '$1' saved to $_SKILL_DIR/.playwright-skill/auth/$1.json"
